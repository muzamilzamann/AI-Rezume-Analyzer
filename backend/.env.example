# ---- General ----
APP_NAME=AI Resume Analyzer
ENVIRONMENT=dev
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# ---- Database (Neon) ----
# Paste your Neon connection string directly. It will be normalized to asyncpg automatically.
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL_MODE=require

# ---- JWT / Auth ----
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RESET_TOKEN_EXPIRE_MINUTES=30

# ---- AI: Google Gemini (added in Week 4) ----
GEMINI_API_KEY=

# ---- Cloudinary (added in Week 2) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
