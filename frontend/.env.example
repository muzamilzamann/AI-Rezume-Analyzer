# Frontend environment variables. Copy to .env and adjust as needed.

# Base URL for the API. In development this is left as /api/v1 so requests are
# proxied to the backend defined in vite.config.ts (http://localhost:8000).
# In production, set this to your deployed backend URL, e.g. https://api.example.com/api/v1
VITE_API_URL=/api/v1
